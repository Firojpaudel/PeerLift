generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String                   @id @default(uuid())
  email             String                   @unique
  emailVerified     DateTime?
  username          String                   @unique
  passwordHash      String?
  name              String
  bio               String?                  @db.VarChar(160)
  avatarUrl         String?
  location          String?
  isAdmin           Boolean                  @default(false)
  isBanned          Boolean                  @default(false)
  banReason         String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  credits           Int                      @default(50)
  lastSeen          DateTime?                @default(now())
  avgRating         Float                    @default(0)
  totalSessions     Int                      @default(0)
  totalReviews      Int                      @default(0)
  searchVector      Unsupported("tsvector")?
  accounts          Account[]
  sessions          AuthSession[]
  availability      Availability[]
  requestsReceived  ExchangeRequest[]        @relation("RequestReceiver")
  requestsSent      ExchangeRequest[]        @relation("RequestSender")
  messages          Message[]
  notifications     Notification[]
  reports           Report[]
  reviewsGiven      Review[]                 @relation("ReviewGiver")
  reviewsReceived   Review[]                 @relation("ReviewReceiver")
  sessionsAsLearner Session[]                @relation("SessionLearner")
  sessionsAsMentor  Session[]                @relation("SessionMentor")
  skillsOffered     UserSkill[]              @relation("SkillsOffered")
  skillsWanted      UserSkill[]              @relation("SkillsWanted")
  friendsSent       Friendship[]             @relation("FriendshipSender")
  friendsReceived   Friendship[]             @relation("FriendshipReceiver")

  @@index([username])
  @@index([email])
  @@index([name])
  @@index([bio])
  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model AuthSession {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model Skill {
  id          String        @id @default(uuid())
  name        String        @unique
  slug        String        @unique
  category    SkillCategory
  description String?
  iconUrl     String?
  isVerified  Boolean       @default(false)
  usageCount  Int           @default(0)
  createdAt   DateTime      @default(now())
  userSkills  UserSkill[]

  @@index([slug])
  @@index([category])
  @@map("skills")
}

model UserSkill {
  id             String     @id @default(uuid())
  offeringUserId String?
  wantingUserId  String?
  skillId        String
  level          SkillLevel
  note           String?    @db.VarChar(200)
  createdAt      DateTime   @default(now())
  userOffering   User?      @relation("SkillsOffered", fields: [offeringUserId], references: [id], onDelete: Cascade)
  skill          Skill      @relation(fields: [skillId], references: [id])
  userWanting         User?             @relation("SkillsWanted", fields: [wantingUserId], references: [id], onDelete: Cascade)
  offeredInRequests   ExchangeRequest[] @relation("OfferedInRequest")
  requestedInRequests ExchangeRequest[] @relation("RequestedInRequest")

  @@map("user_skills")
}

model Availability {
  id        String @id @default(uuid())
  userId    String
  dayOfWeek Int
  startTime String
  endTime   String
  timezone  String @default("UTC")
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("availability")
}

model ExchangeRequest {
  id                      String        @id @default(uuid())
  senderId                String
  receiverId              String
  offeredSkillId          String?
  requestedSkillId        String?
  offeredCredits          Int?
  requestedCredits        Int?
  message                 String
  status                  RequestStatus @default(PENDING)
  counterMessage          String?
  counterOfferedSkillId   String?
  counterRequestedSkillId String?
  parentRequestId         String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  resolvedAt              DateTime?
  
  receiver                User          @relation("RequestReceiver", fields: [receiverId], references: [id])
  sender                  User          @relation("RequestSender", fields: [senderId], references: [id])
  offeredSkill            UserSkill?    @relation("OfferedInRequest", fields: [offeredSkillId], references: [id])
  requestedSkill          UserSkill?    @relation("RequestedInRequest", fields: [requestedSkillId], references: [id])
  session                 Session?

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@map("exchange_requests")
}

model Session {
  id           String          @id @default(uuid())
  requestId    String          @unique
  mentorId     String
  learnerId    String
  skillId      String
  scheduledAt  DateTime
  duration     Int
  timezone     String          @default("UTC")
  status       SessionStatus   @default(SCHEDULED)
  meetingLink  String?
  notes        String?
  cancelReason String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  completedAt  DateTime?
  reviews      Review[]
  learner      User            @relation("SessionLearner", fields: [learnerId], references: [id])
  mentor       User            @relation("SessionMentor", fields: [mentorId], references: [id])
  request      ExchangeRequest @relation(fields: [requestId], references: [id])

  @@index([mentorId])
  @@index([learnerId])
  @@index([scheduledAt])
  @@map("sessions")
}

model Review {
  id         String   @id @default(uuid())
  sessionId  String
  giverId    String
  receiverId String
  rating     Int
  comment    String?
  isPublic   Boolean  @default(true)
  createdAt  DateTime @default(now())
  giver      User     @relation("ReviewGiver", fields: [giverId], references: [id])
  receiver   User     @relation("ReviewReceiver", fields: [receiverId], references: [id])
  session    Session  @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, giverId])
  @@index([receiverId])
  @@map("reviews")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model Report {
  id           String       @id @default(uuid())
  reporterId   String
  targetUserId String
  reason       ReportReason
  description  String?
  status       ReportStatus @default(OPEN)
  resolvedBy   String?
  resolvedAt   DateTime?
  createdAt    DateTime     @default(now())
  reporter     User         @relation(fields: [reporterId], references: [id])

  @@index([status])
  @@map("reports")
}

model Message {
  id           String        @id @default(uuid())
  role         String
  content      String
  isCompressed Boolean       @default(true)
  userId       String
  createdAt    DateTime      @default(now())
  receiverId   String?
  sessionId    String?
  status       MessageStatus @default(SENT)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([receiverId])
  @@index([sessionId])
  @@map("messages")
}

model Friendship {
  id          String           @id @default(uuid())
  senderId    String
  receiverId  String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  sender      User             @relation("FriendshipSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User             @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@map("friendships")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum SkillCategory {
  TECHNICAL
  CREATIVE
  ACADEMIC
  LANGUAGE
  SPORTS
  LIFESTYLE
  BUSINESS
  OTHER
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
  WITHDRAWN
  EXPIRED
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum NotificationType {
  REQUEST_RECEIVED
  REQUEST_ACCEPTED
  REQUEST_REJECTED
  REQUEST_COUNTERED
  SESSION_SCHEDULED
  SESSION_REMINDER
  SESSION_COMPLETED
  REVIEW_RECEIVED
  PROFILE_VIEWED
  SYSTEM
}

enum ReportReason {
  SPAM
  FAKE_PROFILE
  INAPPROPRIATE_CONTENT
  HARASSMENT
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}
